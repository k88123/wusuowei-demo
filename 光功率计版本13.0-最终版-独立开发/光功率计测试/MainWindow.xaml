<Window x:Class="光功率计测试.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:光功率计测试"
        mc:Ignorable="d"
        Title="光功率计数据记录与校准器" Height="900" Width="1200" 
        WindowStartupLocation="CenterScreen" Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFF8F8F8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="DataCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#FFF0F8FF" BorderBrush="#FFB0D8FF" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="connectButton" Content="连接设备" Click="ConnectButton_Click" 
                        Style="{StaticResource PrimaryButton}" Width="100" Height="32"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="statusText" Text="设备未连接" Foreground="#FFD13438" 
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                    <TextBlock x:Name="rawDataText" Text="原始ADC数据: --" Margin="15,0" VerticalAlignment="Center" Foreground="#FF666666"/>
                    <TextBlock x:Name="dataFormatText" Text="数据格式: --" Margin="15,0" VerticalAlignment="Center" Foreground="#FF666666"/>
                </StackPanel>

                <TextBlock x:Name="dataStatusText" Grid.Column="2" Text="数据正常" 
                           Foreground="#FF107C10" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,10,0,15" HorizontalAlignment="Center">
            <Border Style="{StaticResource DataCardStyle}" Width="280">
                <StackPanel>
                    <TextBlock Text="📊 光强数据" FontWeight="Bold" FontSize="13" Foreground="#FF0078D7" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="当前值" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="currentPowerText" Text="--" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="mW" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="#FFE0E0E0" Margin="8,0"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ADC值" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="currentAdcText" Text="--" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="ADC" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DataCardStyle}" Width="280" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="🌡️ 温度数据" FontWeight="Bold" FontSize="13" Foreground="#FFD83B01" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="当前温度" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="currentTempText" Text="--" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="℃" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="#FFE0E0E0" Margin="8,0"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="温度ADC" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="currentTempAdcText" Text="--" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="ADC" FontSize="10" Foreground="#FF666666" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DataCardStyle}" Width="280" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="📈 统计信息" FontWeight="Bold" FontSize="13" Foreground="#FF107C10" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,5">
                            <TextBlock Text="光强(mW)" FontSize="9" Foreground="#FF666666" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最小:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="minPowerText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最大:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="maxPowerText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="平均:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="avgPowerText" Text="--" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,0,5">
                            <TextBlock Text="温度(℃)" FontSize="9" Foreground="#FF666666" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最小:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="minTempText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最大:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="maxTempText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="平均:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="avgTempText" Text="--" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5,5,0">
                            <TextBlock Text="光强ADC" FontSize="9" Foreground="#FF666666" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最小:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="minAdcText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最大:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="maxAdcText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="平均:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="avgAdcText" Text="--" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="5,5,0,0">
                            <TextBlock Text="温度ADC" FontSize="9" Foreground="#FF666666" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最小:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="minTempAdcText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="最大:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="maxTempAdcText" Text="--" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="平均:" FontSize="9" Foreground="#FF666666" Width="25"/>
                                <TextBlock x:Name="avgTempAdcText" Text="--" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <TabControl Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,10" BorderThickness="1" BorderBrush="#FFCCCCCC">
            <TabItem Header="📊 数据监控" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="146*"/>
                        <ColumnDefinition Width="1019*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="实时图表" Grid.Row="0" Style="{StaticResource GroupBoxStyle}" Grid.ColumnSpan="2" Margin="5,5,5,5">
                        <Canvas x:Name="adcChart" Background="White" >
                            <TextBlock x:Name="chartPlaceholderText"
                                       Text="光强ADC与温度值对应的数据图表区域" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                                       Foreground="Gray" FontStyle="Italic"
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                        </Canvas>
                    </GroupBox>

                    <Grid Grid.Row="1" Margin="0,10,0,0" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="⚙️ 阈值设置" Grid.Column="0" Style="{StaticResource GroupBoxStyle}" Width="280">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5" VerticalAlignment="Center">
                                    <TextBlock Text="上限:" Width="40" VerticalAlignment="Center"/>
                                    <TextBox x:Name="upperAdcThresholdTextBox" Width="70" Text="32767" Padding="4"/>
                                    <TextBlock Text="ADC" Margin="8,0" VerticalAlignment="Center" Foreground="#FF666666"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8" VerticalAlignment="Center">
                                    <TextBlock Text="下限:" Width="40" VerticalAlignment="Center"/>
                                    <TextBox x:Name="lowerAdcThresholdTextBox" Width="70" Text="0" Padding="4"/>
                                    <TextBlock Text="ADC" Margin="8,0" VerticalAlignment="Center" Foreground="#FF666666"/>
                                </StackPanel>
                                <Button x:Name="setAdcThresholdButton" Content="应用设置" Margin="0,10,0,5" 
                                        Style="{StaticResource PrimaryButton}" Click="SetAdcThresholdButton_Click"/>
                                <Button x:Name="muteAlertButton" Content="🔕 静音提醒" Margin="0,5" 
                                        Click="MuteAlertButton_Click" Background="Transparent" BorderBrush="#FFCCCCCC"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="📝 记录控制" Grid.Column="1" Style="{StaticResource GroupBoxStyle}" Width="350" Margin="20,0">
                            <StackPanel>
                                <Border Background="#FFF8F8F8" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="温度范围:" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="temperatureRangeText" Text="28℃ → 50℃" Grid.Row="0" Grid.Column="1" Foreground="#FF0078D7" FontWeight="Bold"/>

                                        <TextBlock Text="当前温度:" Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Margin="10,0,5,0"/>
                                        <TextBlock x:Name="currentTemperatureText" Text="--" Grid.Row="0" Grid.Column="3" Foreground="#FFD83B01" FontWeight="Bold"/>

                                        <TextBlock Text="记录状态:" Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Margin="0,5,5,0"/>
                                        <TextBlock x:Name="temperatureProgressText" Text="未开始" Grid.Row="1" Grid.Column="1" Foreground="#FF666666" Margin="0,5,0,0"/>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                    <Button x:Name="startLoggingButton" Content="▶️ 开始记录" Style="{StaticResource PrimaryButton}" 
                                            Click="StartLoggingButton_Click" Width="90"/>
                                    <Button x:Name="stopLoggingButton" Content="⏹️ 停止记录" Style="{StaticResource PrimaryButton}" 
                                            Click="StopLoggingButton_Click" IsEnabled="False" Width="90" Background="#FFD83B01"/>
                                    <Button x:Name="exportDataButton" Content="💾 导出数据" Style="{StaticResource PrimaryButton}" 
                                            Click="ExportDataButton_Click" Width="90"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                                    <CheckBox x:Name="autoLoggingCheckBox" Content="自动记录" Margin="0,0,10,0" 
                                              Checked="AutoLoggingCheckBox_Checked" Unchecked="AutoLoggingCheckBox_Unchecked" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="autoLoggingStatusText" Text="(28℃自动开始，50℃自动停止)" 
                                               Foreground="#FF666666" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock x:Name="loggingStatusText" Text="记录状态: 未开始记录" HorizontalAlignment="Center" 
                                           Margin="0,5" FontWeight="SemiBold" Foreground="#FF666666"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="📐 补偿信息" Grid.Column="2" Style="{StaticResource GroupBoxStyle}" Width="280">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="compensationFactorText" Text="补偿因子: 1.0000" FontSize="16" FontWeight="Bold" 
                                           Foreground="#FF107C10" HorizontalAlignment="Center"/>
                                <TextBlock Text="基于基准温度计算" FontSize="10" Foreground="#FF666666" 
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="🔧 校准表管理" Padding="10,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
                        <Button x:Name="requestPowerTableBtn" Content="📥 请求光功率表" Style="{StaticResource PrimaryButton}" 
                                Click="RequestPowerTableBtn_Click" Width="120"/>
                        <Button x:Name="requestTempTableBtn" Content="📥 请求温度表" Style="{StaticResource PrimaryButton}" 
                                Click="RequestTempTableBtn_Click" Width="120"/>
                        <Button x:Name="savePowerTableBtn" Content="💾 保存光功率表" Style="{StaticResource PrimaryButton}" 
                                Click="SavePowerTableBtn_Click" Width="120"/>
                        <Button x:Name="saveTempTableBtn" Content="💾 保存温度表" Style="{StaticResource PrimaryButton}" 
                                Click="SaveTempTableBtn_Click" Width="120"/>
                        <Rectangle Width="1" Fill="#FFE0E0E0" Margin="15,0"/>
                        <Button x:Name="restoreDefaultsBtn" Content="恢复默认表" Click="RestoreDefaultsBtn_Click" 
                    Margin="2" Width="100" Background="#FFF44336" Foreground="White"/>
                    </StackPanel>

                    <TabControl Grid.Row="1" BorderThickness="1" BorderBrush="#FFCCCCCC">
                        <TabItem Header="📊 光功率校准表">
                            <DataGrid x:Name="powerCalibrationGrid" 
                                    AutoGenerateColumns="False"
                                    IsReadOnly="False"
                                    CanUserAddRows="True"
                                    CanUserDeleteRows="True"
                                    Margin="5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="索引" Binding="{Binding Index}" Width="60"/>
                                    <DataGridTextColumn Header="ADC值" Binding="{Binding AdcValue}" Width="100"/>
                                    <DataGridTextColumn Header="功率值(mW)" Binding="{Binding PowerValue, StringFormat=F4}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="补偿因子表(矩阵)">
                            <DataGrid x:Name="compensationMatrixGrid" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="False" CellEditEnding="CompensationMatrixGrid_CellEditEnding"/>
                        </TabItem>

                    </TabControl>

                    <Border Grid.Row="2" Background="#FFF8F8F8" BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="10,8">
                        <TextBlock x:Name="calibrationStatusText" Text="校准表管理状态" 
                                   Foreground="#FF666666" FontSize="12" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="#FFF5F5F5" BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="数据格式:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <ComboBox x:Name="dataFormatComboBox" Width="180" Padding="6,4" SelectionChanged="DataFormatComboBox_SelectionChanged">
                        <ComboBoxItem Content="16位整数(小端)" IsSelected="True"/>
                        <ComboBoxItem Content="16位整数(大端)"/>
                        <ComboBoxItem Content="12位ADC值"/>
                        <ComboBoxItem Content="10位ADC值"/>
                        <ComboBoxItem Content="原始字节数据"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right">
                    <TextBlock Text="开发者: 张凯胜/Fate(Aidite研发中心)" FontWeight="Bold" FontSize="14" Foreground="#FF0078D7"/>
                    <!--<TextBlock Text="问题联系: [您的联系方式]" FontSize="10" Foreground="#FFD83B01"/>-->
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>